# Copy to .env and fill in. You need ONE model API key for the Ask gesture,
# anchored chat, checkpoints, and symbol definitions.

# Default provider is Groq — genuinely free, no card. Get a key at:
# https://console.groq.com
GROQ_API_KEY=

# Alternatives — set VERITY_LLM_PROVIDER to switch (no code change):
# VERITY_LLM_PROVIDER=groq                 # or: cerebras | gemini
# CEREBRAS_API_KEY=                        # https://cloud.cerebras.ai (may be paid)
# GEMINI_API_KEY=                          # https://aistudio.google.com
# VERITY_LLM_MODEL=llama-3.3-70b-versatile # provider default used if unset

# Optional overrides (sensible defaults exist for all of these):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   # default: local SQLite
# VERITY_CORS_ORIGINS=https://your-frontend.vercel.app   # default: localhost:5173
# VERITY_PDF_MAX_PAGES=50
# VERITY_PDF_MAX_BYTES=41943040
